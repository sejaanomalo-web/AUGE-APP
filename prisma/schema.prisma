generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PERSONAL
  ALUNO
}

enum TrainerStudentStatus {
  PENDING
  ACTIVE
  PAUSED
  ENDED
}

enum WorkoutLogStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum InviteStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum WorkoutMode {
  GUIDED
  FREE
}

enum NotificationType {
  // Para o Aluno
  WORKOUT_PLAN_CREATED
  WORKOUT_PLAN_UPDATED
  WORKOUT_EXERCISE_UPDATED
  WORKOUT_SCHEDULE_UPDATED
  WORKOUT_REMINDER_MORNING
  WORKOUT_REMINDER_EVENING
  STREAK_BROKEN
  EXAM_RECEIVED
  TRAINER_COMMENT

  // Para o Personal
  STUDENT_WORKOUT_STARTED
  STUDENT_WORKOUT_FINISHED
  STUDENT_WORKOUT_SKIPPED
  STUDENT_METRIC_ADDED
  STUDENT_EXAM_UPLOADED
  STUDENT_INVITE_ACCEPTED
}

enum GoalMetric {
  WORKOUT_COUNT    // # de treinos concluídos no período
  DISTANCE_KM      // soma de quilômetros corridos no período
}

enum GoalPeriod {
  WEEK
  MONTH
  YEAR
}

model User {
  id              String    @id
  email           String    @unique
  name            String
  role            UserRole?
  avatarUrl       String?
  phone           String?
  birthDate       DateTime?
  height          Float?
  currentWeight   Float?
  goal            String?
  cref            String?
  sportsPracticed Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trainerLinks    TrainerStudent[] @relation("PersonalRelation")
  studentLinks    TrainerStudent[] @relation("AlunoRelation")
  createdPlans    WorkoutPlan[]    @relation("CreatedByPersonal")
  ownedPlans      WorkoutPlan[]    @relation("PlanOwner")
  workoutLogs     WorkoutLog[]
  bodyMetrics     BodyMetric[]
  examUploads     ExamUpload[]
  runningSessions RunningSession[]
  customExercises Exercise[]       @relation("ExerciseCreator")
  invitesCreated  InviteCode[]     @relation("InviteCreator")
  planMetricLogs  PlanMetricLog[]
  goals           Goal[]

  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  notificationSettings NotificationSettings?

  @@index([email])
  @@index([role])
}

model InviteCode {
  id        String       @id @default(cuid())
  code      String       @unique
  trainerId String
  status    InviteStatus @default(ACTIVE)
  usedById  String?
  expiresAt DateTime
  createdAt DateTime     @default(now())
  usedAt    DateTime?

  trainer User @relation("InviteCreator", fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([trainerId])
}

model TrainerStudent {
  id        String               @id @default(cuid())
  trainerId String
  studentId String
  status    TrainerStudentStatus @default(ACTIVE)
  inviteId  String?
  startedAt DateTime             @default(now())
  endedAt   DateTime?

  trainer User @relation("PersonalRelation", fields: [trainerId], references: [id], onDelete: Cascade)
  student User @relation("AlunoRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([trainerId, studentId])
  @@index([trainerId])
  @@index([studentId])
}

model WorkoutPlan {
  id          String    @id @default(cuid())
  trainerId   String?
  studentId   String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  trainer            User?                  @relation("CreatedByPersonal", fields: [trainerId], references: [id])
  student            User                   @relation("PlanOwner", fields: [studentId], references: [id], onDelete: Cascade)
  sessions           WorkoutSession[]
  metricDefinitions  PlanMetricDefinition[]

  @@index([trainerId])
  @@index([studentId])
}

model WorkoutSession {
  id        String   @id @default(cuid())
  planId    String
  name      String
  dayOfWeek Int?
  order     Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  plan      WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises SessionExercise[]
  logs      WorkoutLog[]

  @@index([planId])
}

model Exercise {
  id           String   @id @default(cuid())
  name         String
  muscleGroup  String
  videoUrl     String?
  imageUrl     String?
  instructions String?
  isCustom     Boolean  @default(false)
  createdById  String?
  createdAt    DateTime @default(now())

  creator          User?             @relation("ExerciseCreator", fields: [createdById], references: [id])
  sessionExercises SessionExercise[]
  exerciseLogs     ExerciseLog[]

  @@index([muscleGroup])
  @@index([createdById])
}

model SessionExercise {
  id          String  @id @default(cuid())
  sessionId   String
  exerciseId  String
  sets        Int
  reps        String
  restSeconds Int?
  weight      Float?
  notes       String?
  order       Int     @default(0)

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
}

model WorkoutLog {
  id           String           @id @default(cuid())
  sessionId    String
  studentId    String
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?
  status       WorkoutLogStatus @default(IN_PROGRESS)
  mode         WorkoutMode      @default(GUIDED)
  notes        String?
  studentNotes String?

  session      WorkoutSession @relation(fields: [sessionId], references: [id])
  student      User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exerciseLogs ExerciseLog[]

  @@index([studentId])
  @@index([sessionId])
  @@index([status])
}

model ExerciseLog {
  id            String   @id @default(cuid())
  workoutLogId  String
  exerciseId    String
  setNumber     Int
  weight        Float?
  reps          Int?
  completed     Boolean  @default(false)
  skipped       Boolean  @default(false)
  skippedReason String?
  loggedAt      DateTime @default(now())

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([workoutLogId])
}

model BodyMetric {
  id           String   @id @default(cuid())
  studentId    String
  date         DateTime @default(now())
  weight       Float?
  bodyFat      Float?
  measurements Json?
  notes        String?
  photoUrl     String?  // optional photo attached to the evaluation
  createdAt    DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([date])
}

model ExamUpload {
  id         String   @id @default(cuid())
  studentId  String
  date       DateTime @default(now())
  type       String
  storageKey String
  fileName   String
  fileSize   Int
  mimeType   String?
  notes      String?
  createdAt  DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model RunningSession {
  id               String   @id @default(cuid())
  studentId        String
  date             DateTime @default(now())
  distanceKm       Float
  durationSeconds  Int
  paceSecondsPerKm Int
  caloriesBurned   Int?
  routeJson        Json?
  notes            String?
  createdAt        DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([date])
}

/// Personal-defined custom metric to collect from the student during a plan.
/// Example: "Peso na barra do supino" (kg), or "Foto da execução do agachamento" (attachment required).
model PlanMetricDefinition {
  id                 String   @id @default(cuid())
  planId             String
  name               String
  unit               String?
  requiresAttachment Boolean  @default(false)
  order              Int      @default(0)
  createdAt          DateTime @default(now())

  plan WorkoutPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  logs PlanMetricLog[]

  @@index([planId])
}

model PlanMetricLog {
  id            String   @id @default(cuid())
  definitionId  String
  studentId     String
  value         String
  attachmentKey String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  definition PlanMetricDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  student    User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([studentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  pushSent  Boolean          @default(false)
  pushError String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationSettings {
  id                  String  @id @default(cuid())
  userId              String  @unique
  morningReminder     Boolean @default(true)
  eveningReminder     Boolean @default(true)
  streakAlerts        Boolean @default(true)
  trainerActivity     Boolean @default(true)
  studentActivity     Boolean @default(true)
  morningReminderHour Int     @default(7)
  eveningReminderHour Int     @default(20)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// User-defined goal — e.g. "5 treinos de Musculação por semana"
/// or "20 km de Corrida por mês". Progress is computed at read-time from
/// WorkoutLog (WORKOUT_COUNT) or RunningSession (DISTANCE_KM) over the
/// active window of `period`.
model Goal {
  id        String     @id @default(cuid())
  studentId String
  sport     String     // mirrors User.sportsPracticed ("Musculação", "Corrida", …)
  metric    GoalMetric
  target    Float
  period    GoalPeriod
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}
